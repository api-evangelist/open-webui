  "info": {
    "_postman_id": "8f3ff808-37e8-4640-9e1e-0dd80e1e5be9",
    "name": "Open WebUI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "REST API exposed by a self-hosted Open WebUI instance. Endpoints include an\nOpenAI-compatible chat completions surface, an Anthropic-compatible messages\nendpoint, and a passthrough proxy for native Ollama endpoints. Authentication\nuses a Bearer token (Open WebUI session token or a per-user API key); each\nAPI key inherits the permissions of the user who created it.\n\n\nContact Support:\n Name: Open WebUI Documentation",
      "type": "text/plain"
    }
  }
